generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
    id       Int    @id @default(autoincrement())
    username String @unique
    password String
}

model SurvivorConfig {
    id        Int      @id @default(autoincrement())
    user      String
    mode      String
    index     Int
    name      String
    image     String
    createdAt DateTime @default(now())
}

model Preset {
    id        Int      @id @default(autoincrement())
    user      String
    mode      String
    survivor  Int
    name      String
    perks     Json
    createdAt DateTime @default(now())

    @@index([user, mode, survivor])
}

model Match {
    id          Int          @id @default(autoincrement())
    user        String?
    mode        String
    result      String
    data        Json
    createdAt   DateTime     @default(now())
    createdBy   String?
    groupId     Int?
    StreakGroup StreakGroup? @relation(fields: [groupId], references: [id])
}

model Streak {
    id          Int          @id @default(autoincrement())
    user        String?
    mode        String
    best        Int          @default(0)
    groupId     Int?
    StreakGroup StreakGroup? @relation(fields: [groupId], references: [id])

    @@unique([user, mode])
    @@unique([groupId, mode])
}

model GroupMember {
    id          Int         @id @default(autoincrement())
    username    String
    groupId     Int
    mode        String
    StreakGroup StreakGroup @relation(fields: [groupId], references: [id])

    @@unique([username, mode])
}

model GroupInvite {
    id        Int      @id @default(autoincrement())
    fromUser  String
    toUser    String
    groupId   Int
    status    String   @default("pending")
    createdAt DateTime @default(now())

    group StreakGroup @relation(fields: [groupId], references: [id])

    @@index([toUser])
}

model StreakGroup {
    id          Int           @id @default(autoincrement())
    mode        String
    owner       String
    createdAt   DateTime      @default(now())
    GroupMember GroupMember[]
    Match       Match[]
    Streak      Streak[]
    GroupInvite GroupInvite[]
}